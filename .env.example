# Database configuration
# Format: postgresql+psycopg://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/postgres

# Spark configuration
SPARK_APP_NAME=EcommerceKPIDemo
SPARK_TIMEZONE=Asia/Seoul

# API configuration
API_PORT=8000

# Grafana configuration
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GRAFANA_POSTGRES_DB=postgres
GRAFANA_POSTGRES_USER=grafana_reader
GRAFANA_POSTGRES_PASSWORD=grafana_reader
