      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "pyspart-postgres-kpi"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_common AS ( SELECT LEAST((SELECT MAX(summary_date) FROM daily_traffic_summary), (SELECT MAX(summary_date) FROM daily_conversion_funnel)) AS summary_date ) SELECT l.summary_date, t.dau_users, f.view_users, f.cart_users, f.order_users, f.payment_users, f.cart_from_view_rate, f.order_from_cart_rate, f.payment_from_order_rate, f.payment_from_view_rate, LEAST(t.aggregation_run_at, f.aggregation_run_at) AS aggregation_run_at, GREATEST(t.aggregation_range_start, f.aggregation_range_start) AS aggregation_range_start, LEAST(t.aggregation_range_end, f.aggregation_range_end) AS aggregation_range_end FROM latest_common l LEFT JOIN daily_traffic_summary t ON t.summary_date = l.summary_date LEFT JOIN daily_conversion_funnel f ON f.summary_date = l.summary_date",
          "refId": "A"
        }
      ],
